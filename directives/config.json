        "type": "json"
      }
    ]
  },
  "user_profile": {
    "type": "solo_ai_builder",
    "focus": [
      "micro_saas",
      "automation",
      "ai_bots",
      "b2b_tools",
      "social_sector_optional"
    ],
    "skills": [
      "nodejs",
      "python",
      "api_integration",
      "automation",
      "ai_agents",
      "bot_building",
      "server_deployment"
    ],
    "strengths": [
      "rapid_prototyping",
      "solo_building",
      "practical_tools"
    ],
    "constraints": {
      "team_size": 1,
      "max_mvp_weeks": 4,
      "prefer_simple_architecture": true
    },
    "preferences": {
      "preferred_opportunity_types": [
        "micro_saas",
        "automation_system",
        "bot_platform"
      ],
      "secondary_opportunity_types": [
        "social_sector_tools",
        "local_ai_tools"
      ],
      "prefer_recurring_revenue": true,
      "prefer_b2b": true,
      "prefer_existing_market": true,
      "avoid": [
        "foundation_models",
        "model_training",
        "data_labeling_business",
        "heavy_ml_research",
        "consumer_social_apps",
        "mobile_only_apps"
      ]
    }
  },
  "dedupe": {
    "titleSimilarityThreshold": 0.6
  },
  "clustering": {
    "mergeThreshold": 0.35,
    "minClusterSize": 1
  },
  "schedule": {
    "cron": "0 7 * * *",
    "timezone": "Europe/Berlin"
  },
  "output": {
    "deliverables_dir": "./deliverables",
    "tmp_dir": "./.tmp",
    "keep_days": 30
  },
  "dashboard": {
    "port": 3456
  }
}
